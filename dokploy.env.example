# Copie estes nomes para a aba Environment do serviço Compose no Dokploy.
# Não use estes valores de exemplo em produção.

# Use somente letras e números ou gere uma senha hexadecimal. Caracteres
# reservados de URL, como @, :, /, ? e #, exigiriam URL encoding em DATABASE_URL.
POSTGRES_PASSWORD=troque-por-uma-senha-hexadecimal-segura

# Estes dois valores podem permanecer como estão, salvo se você precisar de
# outro nome de usuário ou banco por uma razão específica.
POSTGRES_USER=postgres
POSTGRES_DB=g4_assistente

# Gere com: openssl rand -base64 32
AUTH_SECRET=troque-por-um-segredo-aleatorio

# Exatamente 64 caracteres hexadecimais. Gere com: openssl rand -hex 32
# ATENÇÃO: guarde uma cópia segura. Sem essa chave, não será possível
# descriptografar a chave OpenAI salva no banco.
ENCRYPTION_KEY=troque-por-64-caracteres-hexadecimais

